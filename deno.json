{
  "tasks": {
    "start": "deno --env-file --allow-env --allow-ffi src/app.ts",
    "dev": "deno --env-file --allow-env --allow-ffi src/station_dev.ts"
  },

  "imports": {
    "@logtape/logtape": "jsr:@logtape/logtape@^2.0.5",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.18",
    "decoder": "./src/audio/decoder.ts",
    "encoder": "./src/audio/encoder.ts",
    "filtergraph": "./src/audio/filtergraph.ts",
    "mutex": "./src/audio/mutex.ts",
    "station": "./src/station.ts"
  },
  "test": {
    "permissions": {
      "env": ["SUPPORT_PATH"],
      "ffi": true,
      "read": ["./test.flac", "./corrupted.flac"],
      "write": [
        "./test.flac",
        "corrupted.flac",
        "test.mp3",
        "inappropriate_container_codec.ogg",
        "pink.flac"
      ]
    }
  }
}
